# WildCard — Environment Variables
# Copy to .env and fill in real values.

# Server
PORT=3001
NODE_ENV=production
SITE_URL=https://wildcard.you
ALLOWED_ORIGIN=https://wildcard.you

# Auth (stub — disabled in production until AUTH_ENABLED=true)
# AUTH_ENABLED=true
# AUTH_SECRET=replace-with-random-secret

# Admin moderation access
# ADMIN_TOKEN=replace-with-random-secret

# Database (future)
# DATABASE_URL=postgresql://user:password@localhost:5432/wildcard

# Object Storage (future)
# S3_ENDPOINT=https://your-bucket.fsn1.your-objectstorage.com
# S3_ACCESS_KEY=your-access-key
# S3_SECRET_KEY=your-secret-key
# S3_BUCKET=wildcard
